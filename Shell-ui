--============================================================
-- AddGame â€” daftarkan satu kartu game di sidebar
-- config = {
--   Name, Category, Tagline, IconEmoji, Status,
--   Favorite = true/false,
--   AntiLagOptions = { {Name="LOW", SubText="~60 FPS", Value="low"}, ... },
--   Utilities = { {Name="Anti AFK", Default=false, Callback=function(state) end}, ... },
--   OnExecute = function() end,          -- kamu isi sendiri
--   OnAntiLagSelect = function(value) end,
-- }
--============================================================
function EWEHUB:AddGame(config)
	config = config or {}
	local hub = self

	local Card = New("TextButton", {
		Text = "", BackgroundColor3 = Theme.Card, Size = UDim2.new(1, 0, 0, 76),
		AutoButtonColor = false, Parent = self.GameList,
	}, { Corner(10), Stroke() })

	local AccentBar = New("Frame", { Size = UDim2.new(0, 3, 1, -16), Position = UDim2.new(0, 0, 0, 8), BackgroundColor3 = Theme.AccentRed, Visible = false, Parent = Card }, { Corner(2) })

	local Icon = New("TextLabel", {
		Size = UDim2.new(0, 50, 0, 50), Position = UDim2.new(0, 12, 0.5, -25),
		BackgroundColor3 = Theme.PanelLight, Text = config.IconEmoji or "ðŸŽ®", TextSize = 22,
		TextXAlignment = Enum.TextXAlignment.Center, TextYAlignment = Enum.TextYAlignment.Center,
		Parent = Card,
	}, { Corner(10) })

	if config.Favorite then
		New("TextLabel", {
			Text = "â˜…", Font = Enum.Font.GothamBold, TextSize = 12, TextColor3 = Theme.Star,
			BackgroundColor3 = Theme.Panel, Size = UDim2.new(0, 18, 0, 18),
			Position = UDim2.new(0, 44, 0, -2), Parent = Card,
		}, { Corner(9) })
	end

	New("TextLabel", {
		Text = config.Name or "Game", Font = Enum.Font.GothamBold, TextSize = 15, TextColor3 = Theme.Text,
		BackgroundTransparency = 1, Position = UDim2.new(0, 72, 0, 10), Size = UDim2.new(1, -84, 0, 18),
		TextXAlignment = Enum.TextXAlignment.Left, Parent = Card,
	})
	New("TextLabel", {
		Text = config.Category or "", Font = Enum.Font.GothamBold, TextSize = 11, TextColor3 = Theme.AccentRed,
		BackgroundTransparency = 1, Position = UDim2.new(0, 72, 0, 30), Size = UDim2.new(1, -84, 0, 14),
		TextXAlignment = Enum.TextXAlignment.Left, Parent = Card,
	})
	New("TextLabel", {
		Text = config.Tagline or "", Font = Enum.Font.Gotham, TextSize = 12, TextColor3 = Theme.SubText,
		BackgroundTransparency = 1, Position = UDim2.new(0, 72, 0, 48), Size = UDim2.new(1, -84, 0, 16),
		TextXAlignment = Enum.TextXAlignment.Left, Parent = Card,
	})

	local gameEntry = { Name = config.Name or "Game", CardFrame = Card, Config = config }
	table.insert(self.Games, gameEntry)
	self.ScriptCountLabel.Text = #self.Games .. " SCRIPTS"

	local function SelectThisGame()
		for _, g in ipairs(self.Games) do
			Tween(g.CardFrame, FastTween, { BackgroundColor3 = Theme.Card })
		end
		Tween(Card, FastTween, { BackgroundColor3 = Theme.CardActive })

		hub.EmptyState.Visible = false
		hub.DetailPanel.Visible = true
		hub.DetailIcon.Text = config.IconEmoji or "ðŸŽ®"
		hub.DetailTitle.Text = config.Name or "Game"
		hub.Tagline.Text = config.Tagline or ""

		local isOnline = (config.Status or "online") == "online"
		hub.StatusDot.BackgroundColor3 = isOnline and Theme.Accent or Theme.SubText
		hub.StatusLabel.Text = isOnline and "ONLINE" or "OFFLINE"
		hub.StatusLabel.TextColor3 = isOnline and Theme.Accent or Theme.SubText

		if hub._executeConn then hub._executeConn:Disconnect() end
		hub._executeConn = hub.ExecuteBtn.MouseButton1Click:Connect(function()
			Tween(hub.ExecuteBtn, TweenInfo.new(0.08), { BackgroundColor3 = Theme.Accent })
			task.delay(0.12, function() Tween(hub.ExecuteBtn, FastTween, { BackgroundColor3 = Theme.AccentRed }) end)
			if config.OnExecute then task.spawn(config.OnExecute) end -- <-- kamu isi sendiri
		end)

		for _, child in ipairs(hub.AntiLagGrid:GetChildren()) do
			if child:IsA("GuiObject") then child:Destroy() end
		end
		for i, opt in ipairs(config.AntiLagOptions or {}) do
			local OptBtn = New("TextButton", {
				Text = "", BackgroundColor3 = Theme.PanelLight, LayoutOrder = i,
				AutoButtonColor = false, Parent = hub.AntiLagGrid,
			}, { Corner(8), Stroke() })
			New("TextLabel", {
				Text = opt.Name, Font = Enum.Font.GothamBold, TextSize = 12, TextColor3 = Theme.Text,
				BackgroundTransparency = 1, Position = UDim2.new(0, 0, 0.55, 0), Size = UDim2.new(1, 0, 0, 16),
				Parent = OptBtn,
			})
			New("TextLabel", {
				Text = opt.SubText or "", Font = Enum.Font.Gotham, TextSize = 10, TextColor3 = Theme.SubText,
				BackgroundTransparency = 1, Position = UDim2.new(0, 0, 0.78, 0), Size = UDim2.new(1, 0, 0, 12),
				Parent = OptBtn,
			})
			OptBtn.MouseButton1Click:Connect(function()
				for _, sib in ipairs(hub.AntiLagGrid:GetChildren()) do
					if sib:IsA("TextButton") then Tween(sib, FastTween, { BackgroundColor3 = Theme.PanelLight }) end
				end
				Tween(OptBtn, FastTween, { BackgroundColor3 = Theme.CardActive })
				if config.OnAntiLagSelect then task.spawn(config.OnAntiLagSelect, opt.Value) end
			end)
		end

		for _, child in ipairs(hub.UtilList:GetChildren()) do
			if child:IsA("GuiObject") then child:Destroy() end
		end
		for i, util in ipairs(config.Utilities or {}) do
			local state = util.Default or false
			local UtilHolder = New("Frame", { BackgroundColor3 = Theme.PanelLight, LayoutOrder = i, Parent = hub.UtilList }, { Corner(8), Stroke() })
			local Switch = New("Frame", {
				Size = UDim2.new(0, 34, 0, 18), Position = UDim2.new(0, 10, 0.5, -9),
				BackgroundColor3 = state and Theme.Accent or Theme.Stroke, Parent = UtilHolder,
			}, { Corner(9) })
			local Knob = New("Frame", {
				Size = UDim2.new(0, 14, 0, 14),
				Position = state and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7),
				BackgroundColor3 = Color3.fromRGB(255, 255, 255), Parent = Switch,
			}, { Corner(7) })
			New("TextLabel", {
				Text = util.Name or "Utility", Font = Enum.Font.GothamMedium, TextSize = 12, TextColor3 = Theme.Text,
				BackgroundTransparency = 1, Position = UDim2.new(0, 52, 0, 0), Size = UDim2.new(1, -60, 1, 0),
				TextXAlignment = Enum.TextXAlignment.Left, Parent = UtilHolder,
			})
			local ClickArea = New("TextButton", { Text = "", BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, 0), Parent = UtilHolder })
			ClickArea.MouseButton1Click:Connect(function()
				state = not state
				Tween(Switch, FastTween, { BackgroundColor3 = state and Theme.Accent or Theme.Stroke })
				Tween(Knob, FastTween, { Position = state and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7) })
				if util.Callback then task.spawn(util.Callback, state) end -- <-- kamu isi sendiri
			end)
		end
	end

	Card.MouseButton1Click:Connect(SelectThisGame)
	Card.MouseEnter:Connect(function() Tween(Card, FastTween, { BackgroundColor3 = Theme.CardActive }) end)
	Card.MouseLeave:Connect(function() Tween(Card, FastTween, { BackgroundColor3 = Theme.Card }) end)
	gameEntry.Select = SelectThisGame
	return gameEntry
end

return EWEHUB

